# Copy this file to .env and fill in your values.
#   cp .env.example .env

# IP address to bind the dashboard to.
# Options:
#   - Your Tailscale IP (e.g. 100.x.x.x)  → access from any Tailscale device
#   - 127.0.0.1                             → localhost only, use SSH port forwarding
#   - 0.0.0.0                               → all interfaces (not recommended)
BIND_HOST=127.0.0.1

# Port exposed on the host.
BIND_PORT=8081

# Docker container name.
CONTAINER_NAME=activity-monitor
